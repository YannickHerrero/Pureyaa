{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": { "resourceClass": "large" }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "android": { "resourceClass": "large" }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": { "resourceClass": "large" }
    }
  },
  "submit": {
    "production": {}
  }
}
