{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192"
      },
      "android": { "resourceClass": "large" }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "staging": {
      "extends": "base",
      "distribution": "internal",
      "channel": "staging"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
