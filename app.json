{
  "expo": {
    "name": "Pureyaa",
    "slug": "pureyaa",
    "version": "0.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pureyaa",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#DDE4D2"
    },
    "android": {
      "package": "com.pureyaa.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#DDE4D2"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-video",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT"
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6bd145bf-f059-435e-9d30-eb5b9ca19864"
      }
    },
    "owner": "yherrero",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6bd145bf-f059-435e-9d30-eb5b9ca19864"
    },
    "ios": {}
  }
}
